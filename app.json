{
  "expo": {
    "name": "MatUp",
    "slug": "matup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "matup",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.matup.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MatUp uses your location to find events and courts near you.",
        "NSCameraUsageDescription": "MatUp uses your camera to take profile photos.",
        "NSPhotoLibraryUsageDescription": "MatUp accesses your photos for profile and event images."
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MatUp uses your location to find events and courts near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MatUp accesses your photos for profile and event images.",
          "cameraPermission": "MatUp uses your camera to take profile photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f97316"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "android": {
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.matup.app"
    }
  }
}
